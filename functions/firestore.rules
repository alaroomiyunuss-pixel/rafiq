rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isParticipant(participants) { return isAuth() && request.auth.uid in participants; }

    // USERS
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && (!('role' in request.resource.data) || request.resource.data.role in ['passenger','driver','both']);
      allow delete: if false;

      match /vehicles/{vehicleId} {
        allow read: if isAuth();
        allow create, update, delete: if isOwner(uid);
      }

      // NEW: finance wallet doc
      match /finance/{docId} {
        // We will use docId == "wallet"
        allow read: if isOwner(uid);
        allow write: if false; // only via Cloud Functions / Admin
      }

      // NEW: finance ledger entries
      match /financeLedger/{entryId} {
        allow read: if isOwner(uid);
        allow write: if false; // only via Cloud Functions / Admin
      }
    }

    // TRIPS
    match /trips/{tripId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.status == 'open';

      allow update: if isAuth()
        && resource.data.driverId == request.auth.uid
        && !('availableSeats' in request.resource.data && request.resource.data.availableSeats != resource.data.availableSeats)
        && !('confirmedBookings' in request.resource.data && request.resource.data.confirmedBookings != resource.data.confirmedBookings);

      allow delete: if isAuth()
        && resource.data.driverId == request.auth.uid
        && resource.data.confirmedBookings == 0;
    }

    // BOOKINGS (created/updated by Cloud Functions)
    match /bookings/{bookingId} {
      allow read: if isAuth()
        && (resource.data.passengerId == request.auth.uid || resource.data.driverId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // CONVERSATIONS
    match /conversations/{convoId} {
      allow read: if isAuth() && isParticipant(resource.data.participants);
      allow create: if false;
      allow update: if isAuth() && isParticipant(resource.data.participants);

      match /messages/{messageId} {
        allow read: if isAuth() && isParticipant(
          get(/databases/$(database)/documents/conversations/$(convoId)).data.participants
        );
        allow create: if isAuth()
          && isParticipant(get(/databases/$(database)/documents/conversations/$(convoId)).data.participants)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() && isParticipant(
          get(/databases/$(database)/documents/conversations/$(convoId)).data.participants
        );
        allow delete: if false;
      }
    }

    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

    // CONFIG
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // CITIES
    match /cities/{cityId} {
      allow read: if true;
      allow write: if false;
    }

    // RESERVED (locked)
    match /companies/{doc} { allow read, write: if false; }
    match /adminUsers/{doc} { allow read, write: if false; }
    match /supportTickets/{doc} { allow read, write: if false; }
    match /promoCodes/{doc} { allow read, write: if false; }
    match /notifications/{uid}/items/{doc} { allow read, write: if false; }
    match /verifications/{doc} { allow read, write: if false; }
  }
}
